# Supabase PostgreSQL Database (Connection Pooling string)
DATABASE_URL="postgres://postgres.xxxxx:password@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Upstash Redis
REDIS_URL="rediss://default:password@REGION.upstash.io:6379"

# JWT Secret for Production (Change this to a strong random string!)
JWT_SECRET="YOUR_SUPER_SECRET_PRODUCTION_KEY"

# Server Port
PORT=3000

# Client URL (for CORS)
CLIENT_URL="https://your-production-app.com"
